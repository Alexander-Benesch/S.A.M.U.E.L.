{
  "version": "eu_ai_act_2024_1689",
  "_note": "EU AI Act (Regulation 2024/1689) article references for SAMUEL events. Articles cited: 12 (Logging), 13 (Transparency), 14 (Human Oversight), 15 (Robustness), 50 (AI-generated content). Edit this file to add new mappings — no code reload needed.",
  "articles": [
    {
      "id": "Art. 12",
      "title": "Logging",
      "description": "Aufzeichnungspflicht (Logging) für High-Risk AI Systems — automatische Protokollierung relevanter Ereignisse über die gesamte Lebensdauer des Systems."
    },
    {
      "id": "Art. 13",
      "title": "Transparency",
      "description": "Transparenz und Information für Nutzer — Anbieter müssen betroffene Nutzer eindeutig informieren, wenn ein AI-System eingesetzt wird."
    },
    {
      "id": "Art. 14",
      "title": "Human Oversight",
      "description": "Menschliche Aufsicht (Human Oversight) — High-Risk AI Systems müssen von natürlichen Personen wirksam beaufsichtigt werden können (Stop-/Override-Mechanismen)."
    },
    {
      "id": "Art. 15",
      "title": "Robustness & Cybersecurity",
      "description": "Genauigkeit, Robustheit und Cybersicherheit — Resilienz gegen Fehler, Inkonsistenzen, Adversarial-Inputs."
    },
    {
      "id": "Art. 50",
      "title": "Transparency for AI-generated Content",
      "description": "Transparenzpflichten für AI-generierte Inhalte — Output muss als künstlich erzeugt gekennzeichnet werden (Watermarking, AI-Attribution)."
    }
  ],
