{
  "version": "owasp_top10_agentic_2024_internal",
  "_note": "Project-internal OWASP Top 10 for Agentic AI taxonomy (2024 draft vocabulary). ASI01-ASI10 migration is tracked in #290. Edit this file to add new mappings or fallback categories — no code reload needed, samuel re-reads on import.",
  "categories": [
    {
      "id": "A01",
      "key": "unrestricted_agency",
      "name": "Unrestricted Agency",
      "description": "Agent führt Aktionen ohne Berechtigungs-Schranken aus — z.B. Self-Repair, Force-Push, Schranken-Übergehen."
    },
    {
      "id": "A02",
      "key": "uncontrolled_behavior",
      "name": "Uncontrolled Agentic Behavior",
      "description": "Agent zeigt unkontrolliertes Verhalten ohne Aufsicht — z.B. Approval-Bypass, Workflow-Entgleisung, Konfig-Änderung."
    },
    {
      "id": "A03",
      "key": "inadequate_sandboxing",
      "name": "Inadequate Sandboxing",
      "description": "Agent kann Sandbox/Worktree-Schutz unterlaufen — z.B. Quality-Gate-Bypass, Step-Bypass, Self-Check-Failure."
    },
    {
      "id": "A04",
      "key": "broken_trust_boundaries",
      "name": "Broken Trust Boundaries",
      "description": "Agent verletzt Slice-/Modul-/System-Grenzen — z.B. Cross-Slice-Import, destruktive Merges, Branch-Stale."
    },
    {
      "id": "A05",
      "key": "identity_access_abuse",
      "name": "Identity & Access Abuse",
      "description": "Agent missbraucht Identität oder Zugriffsrechte — z.B. unbefugte Issue-/Label-/Comment-Operations, Env-Exposure."
    },
    {
      "id": "A06",
      "key": "unmonitored_activities",
      "name": "Unmonitored Agent Activities",
      "description": "Agent-Aktivitäten ohne Audit-Trail oder Logging — z.B. LLM-Calls, System-Events, Health-Checks ohne Sichtbarkeit."
    },
    {
      "id": "A07",
      "key": "unsafe_tool_integration",
      "name": "Unsafe Tool/API Integration",
      "description": "Agent ruft Tools/APIs unsicher auf — z.B. Patch-Apply, Changelog-Update, PR-Exists ohne Validation."
    },
    {
      "id": "A08",
      "key": "excessive_autonomy",
      "name": "Excessive Autonomy",
      "description": "Agent agiert autonomer als nötig — z.B. eigenmächtiges Healing, Auto-Implementation, Self-Repair."
    },
    {
      "id": "A09",
      "key": "inadequate_feedback_loops",
      "name": "Inadequate Feedback Loops",
      "description": "Eval-/Test-/AC-Verifikations-Schleifen unzureichend — Score-Aussagekraft kompromittiert, Test-Failures unbemerkt."
    },
    {
      "id": "A10",
      "key": "opaque_reasoning",
      "name": "Opaque Agent Reasoning",
      "description": "Agent-Entscheidungen sind nicht nachvollziehbar — Routing/Context-Auswahl ohne Begründung, intransparente Plan-Generierung."
    }
  ],
