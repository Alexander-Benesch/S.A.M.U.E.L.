# --- SCM (Pflicht) ---
SCM_PROVIDER=gitea
SCM_URL=http://192.168.1.60:3001
SCM_TOKEN=your-token-here
SCM_REPO=owner/repo
SCM_USER=your-username
SCM_BOT_USER=samuel-bot

# --- LLM (mindestens ein Provider) ---
# DEEPSEEK_API_KEY=sk-...
# GEMINI_API_KEY=AI...
# OLLAMA_URL=http://localhost:11434

# --- Sicherheit ---
# SLICE_HMAC_KEY=random-32-byte-hex

# --- Verzeichnisse (optional, Defaults in config/agent.json) ---
# PROJECT_ROOT=/path/to/target/project
# CONTEXT_DIR=/path/to/context
